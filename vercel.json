{
  "rewrites": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "reggy.io"
        }
      ],
      "destination": "/landing.html"
    },
    {
      "source": "/blog",
      "has": [
        {
          "type": "host",
          "value": "reggy.io"
        }
      ],
      "destination": "/blog/index.html"
    },
    {
      "source": "/blog/:slug",
      "has": [
        {
          "type": "host",
          "value": "reggy.io"
        }
      ],
      "destination": "/blog/:slug.html"
    },
    {
      "source": "/((?!landing\\.html|blog|assets|favicon|icons|og-|manifest).*)",
      "has": [
        {
          "type": "host",
          "value": "reggy.io"
        }
      ],
      "destination": "/landing.html"
    }
  ]
}
