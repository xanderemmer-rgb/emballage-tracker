{
  "rewrites": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "reggy.io"
        }
      ],
      "destination": "/landing.html"
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.reggy.io"
        }
      ],
      "destination": "/landing.html"
    }
  ]
}
